# ══════════════════════════════════════════════
# SKYWATCH — Configuration
# ══════════════════════════════════════════════
# Copier ce fichier en .env et remplir les clés

# Port du serveur (défaut: 3000)
PORT=3000

# ── OpenWeather API ──────────────────────────
# Gratuit : https://openweathermap.org/api → "Current Weather Data"
# Limite : 1000 appels/jour (gratuit)
OPENWEATHER_API_KEY=your_openweather_key_here

# ── Windy Webcams API ────────────────────────
# Gratuit : https://api.windy.com → section Webcams
# Limite : 1000 appels/jour (gratuit)
WINDY_API_KEY=your_windy_key_here

# ── Cache TTL (secondes) ─────────────────────
CACHE_TTL_WEATHER=600
CACHE_TTL_WEBCAMS=3600

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ── CORS Origin (production) ─────────────────
CORS_ORIGIN=*
